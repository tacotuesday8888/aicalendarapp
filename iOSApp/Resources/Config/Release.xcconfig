PRODUCT_BUNDLE_IDENTIFIER = com.langqi.aicalendarapp
APP_DISPLAY_NAME = AI Efficiency
APP_URL_SCHEME = aicalendarapp
APS_ENVIRONMENT = production
IPHONEOS_DEPLOYMENT_TARGET = 17.0
SWIFT_VERSION = 5.0
CURRENT_PROJECT_VERSION = 1
MARKETING_VERSION = 1.0
API_BASE_URL =
AI_API_BASE_URL =
// RevenueCat release builds require the platform-specific iOS public SDK key (`appl_...`).
// Never use a RevenueCat secret API key (`sk_...`) or OAuth token (`atk_...`) in the app.
REVENUECAT_API_KEY =
REVENUECAT_ENTITLEMENT_ID = aiefficiencyapp Pro
// Superwall release builds require the public SDK API key from Settings > Keys (`pk_...`).
SUPERWALL_API_KEY =
// Google Sign-In release builds require the iOS OAuth client ID and matching reversed client ID URL scheme.
GOOGLE_CLIENT_ID =
GOOGLE_REVERSED_CLIENT_ID =
// Release builds require publicly accessible HTTPS legal URLs.
PRIVACY_POLICY_URL =
TERMS_OF_SERVICE_URL =
// Release builds also require the App Store support URL.
SUPPORT_URL =
#include? "Secrets.xcconfig"
