rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userID) {
      return isSignedIn() && request.auth.uid == userID;
    }

    match /users/{userID} {
      allow read, write: if isOwner(userID);

      match /{collection}/{documentID} {
        allow read: if isOwner(userID);

        allow create, update, delete: if isOwner(userID) && collection in [
          "onboarding",
          "goals",
          "plannerBlocks",
          "courses",
          "assignments",
          "habits",
          "studySessions",
          "checkIns",
          "vibeChecks",
          "reminderRules"
        ];
      }

      match /assistantThreads/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /goalPlans/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /imports/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /subscriptions/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /aiUsageLogs/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /assistantDraftArtifacts/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }
    }
  }
}
