rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userID) {
      return isSignedIn() && request.auth.uid == userID;
    }

    function isClientWritableCollection(collection) {
      return collection in [
        "onboarding",
        "goals",
        "plannerBlocks",
        "courses",
        "assignments",
        "habits",
        "studySessions",
        "checkIns",
        "vibeChecks",
        "reminderRules"
      ];
    }

    function isServerReadableCollection(collection) {
      return collection in [
        "assistantThreads",
        "goalPlans",
        "imports",
        "subscriptions",
        "aiUsageLogs",
        "aiUsage",
        "aiUsageDaily",
        "aiDrafts",
        "assistantDraftArtifacts"
      ];
    }

    function isReadableUserCollection(collection) {
      return isClientWritableCollection(collection) || isServerReadableCollection(collection);
    }

    match /users/{userID} {
      allow read, write: if isOwner(userID);

      match /{collection}/{documentID} {
        allow read: if isOwner(userID) && isReadableUserCollection(collection);

        allow create, update, delete: if isOwner(userID) && isClientWritableCollection(collection);
      }

      match /assistantThreads/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /goalPlans/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /imports/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /subscriptions/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /aiUsageLogs/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /aiUsage/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /aiUsageDaily/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /aiDrafts/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }

      match /assistantDraftArtifacts/{documentID} {
        allow read: if isOwner(userID);
        allow write: if false;
      }
    }
  }
}
