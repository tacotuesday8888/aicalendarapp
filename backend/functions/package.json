{
  "name": "aicalendarapp-functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "ai:smoke": "tsx scripts/aiSmokeTest.ts",
    "functions:live-smoke": "tsx scripts/liveFunctionSmokeTest.ts",
    "build": "tsc -p tsconfig.json",
    "genkit:ui": "genkit start -- npx tsx --watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "rules:test": "cd ../.. && npm --prefix backend/functions exec -- firebase emulators:exec --project demo-aicalendarapp --only firestore,storage \"npm --prefix backend/functions run rules:test:run\"",
    "rules:test:run": "tsx scripts/rulesBehaviorTest.ts",
    "typecheck:scripts": "tsc -p tsconfig.scripts.json --noEmit",
    "serve": "npx -y firebase-tools@latest emulators:start --only functions",
    "deploy": "npx -y firebase-tools@latest deploy --only functions"
  },
  "dependencies": {
    "@genkit-ai/google-genai": "^1.34.0",
    "firebase-admin": "^14.0.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.34.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.15.0",
    "firebase-tools": "^15.21.0",
    "genkit-cli": "^1.34.0",
    "tsx": "^4.22.0",
    "typescript": "^5.8.2"
  }
}
