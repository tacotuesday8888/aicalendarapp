{
  "name": "aicalendarapp-functions",
  "private": true,
  "engines": {
    "node": "22"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "genkit:ui": "genkit start -- npx tsx --watch src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "serve": "npx -y firebase-tools@latest emulators:start --only functions",
    "deploy": "npx -y firebase-tools@latest deploy --only functions"
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.6.0",
    "genkit": "^1.33.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "genkit-cli": "^1.33.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
