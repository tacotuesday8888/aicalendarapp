# AI v1 uses Firebase Functions + Genkit. Use stub only for local smoke tests.
AI_PROVIDER=vertex
AI_MODEL=gemini-3.1-flash-lite
AI_VERTEX_LOCATION=global
AI_ENABLE_STUB_FALLBACK=false

# Match this to the exact Authorization header value configured in RevenueCat.
REVENUECAT_WEBHOOK_SECRET=
# Lets the backend verify and sync subscription status immediately after purchase/restore.
REVENUECAT_SECRET_API_KEY=
REVENUECAT_ENTITLEMENT_ID=aiefficiencyapp Pro
REVENUECAT_MONTHLY_PRODUCT_ID=
REVENUECAT_ANNUAL_PRODUCT_ID=

# off | monitor | enforce. Keep monitor until App Check dashboard registration and debug tokens are verified.
APP_CHECK_MODE=monitor

# Optional quota overrides. Defaults to 50/day when unset.
BETA_PRO_USER_IDS=
AI_FREE_DAILY_LIMIT=
AI_PREMIUM_DAILY_LIMIT=
AI_SUBSCRIPTION_SNAPSHOT_MAX_AGE_HOURS=24
AI_DAILY_LIMIT_ASSISTANT_CHAT_ACTIVE=
AI_DAILY_LIMIT_GOAL_PLAN_GENERATION_ACTIVE=
AI_DAILY_LIMIT_SYLLABUS_IMPORT_ACTIVE=
AI_DAILY_LIMIT_VIBE_FEEDBACK_INACTIVE=
AI_DAILY_LIMIT_VIBE_FEEDBACK_ACTIVE=
